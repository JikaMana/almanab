---
import "../styles/global.css";
import icon from "../assets/almanab.svg"

---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Al Manāb | Apparels & Technologies in Nigeria</title>
  <meta name="title" content="Al Manāb | Apparels & Technologies in Nigeria" />
  <meta name="description" content="Al Manāb is a Nigerian enterprise offering premium Islamic apparel including Jallabiya and high-performance software solutions, web development, and mobile app development. Based in Port Harcourt, serving clients nationwide." />
  <meta name="keywords" content="Al Manab, Jallabiya Nigeria, Islamic clothing Nigeria, Web development Nigeria, Mobile app development Nigeria, Software company Nigeria, Tech company Port Harcourt" />
  <meta name="author" content="Al Manāb Group" />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href="https://almanab.com/" />

  <meta property="og:type" content="website" />
  <meta property="og:title" content="Al Manāb | Apparels & Technologies" />
  <meta property="og:description" content="Premium Jallabiya, Islamic apparel, and cutting-edge software solutions in Nigeria." />
  <meta property="og:url" content="https://almanab.com/" />
  <meta property="og:image" content="https://almanab.com/og-image.jpg" />
  <meta property="og:site_name" content="Al Manāb" />
  <meta property="og:locale" content="en_NG" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Al Manāb | Apparels & Technologies" />
  <meta name="twitter:description" content="Premium Islamic apparel and modern software development services in Nigeria." />
  <meta name="twitter:image" content="https://almanab.com/og-image.jpg" />

  <meta name="geo.region" content="NG" />
  <meta name="geo.placename" content="Port Harcourt, Nigeria" />
  <meta name="theme-color" content="#0f172a" />

  <link rel="icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- NAVIGATION -->
  <nav>
    <div class="logo">
      <a href="/">
        <img src={icon.src} alt="AL MANAB" width="80" />
      </a>
    </div>
    <div class="nav-links">
      <a href="#tech">Technologies</a>
      <a href="#apparels">Apparels</a>
      <a href="#about">About</a>
      <a href="#contact">Contact</a>
    </div>
  </nav>

  <!-- HERO─ -->
  <section class="hero">
    <div class="hero-subtitle">
      <span class="anim-up">AMB TECHNOLOGIES. Serving Nationwide.</span>
    </div>
    <h1 class="hero-title">
      <span class="line"><span class="anim-up">Crafting Digital</span></span>
      <span class="line"><span class="anim-up">Futures & Cultural</span></span>
      <span class="line"><span class="anim-up">Elegance.</span></span>
    </h1>
    <p class="hero-desc">
      Al Manāb is a dual-faceted enterprise dedicated to writing cutting-edge
      software solutions and creating premium, authentic Islamic apparel.
    </p>
    <div class="scroll-indicator">
      <span>Scroll to Explore</span>
      <div class="scroll-line"></div>
    </div>
  </section>

  <!--
   HORIZONTAL SCROLL WRAPPER
    Contains exactly TWO .panel children.
    GSAP pins this element and slides the panels left on scroll.
    Nothing else should be inside this wrapper.
  -->
  <div class="horizontal-sections">

    <!-- Panel 1 – Technologies -->
    <section id="tech" class="division tech-section panel">
      <div class="division-inner">
        <div class="div-content">
          <div class="div-label">Al Manāb Technologies</div>
          <h2 class="div-title">Innovating the Digital Space.</h2>
          <p class="div-text">
            We build aesthetic, high-performance software tailored to your
            needs. From intuitive mobile applications to scalable web platforms,
            we engineer the tools that drive businesses forward.
          </p>
          <ul class="features-list">
            <li><i data-lucide="smartphone"></i> Custom Mobile Applications</li>
            <li><i data-lucide="monitor"></i> Web Apps & Premium Websites</li>
            <li><i data-lucide="graduation-cap"></i> Software Training & Bootcamps for Beginners</li>
          </ul>
          <a class="visit-button" href="https://almanabtech.netlify.app/" target="_blank">VISIT AMB TECHNOLOGY</a>
          <div class="social-links" style="margin-top: 2rem;">
            <a href="mailto:almanabtech@gmail.com">
              <i data-lucide="mail" style="width: 18px;"></i>
              almanabtech@gmail.com
            </a>
            <a href="https://instagram.com/almanab.tech" target="_blank">
              <i data-lucide="instagram" style="width: 18px;"></i>
              @almanab.tech
            </a>
          </div>
        </div>
        <div class="div-image-container">
          <img
            src="https://images.unsplash.com/photo-1555066931-4365d14bab8c?q=80&w=2070&auto=format&fit=crop"
            alt="Coding and Software Development"
            class="div-image img-tech"
          />
        </div>
      </div>
    </section>

    <!-- Panel 2 – Process -->
    <section class="process-section panel">
      <div class="process-inner">
        <div class="process-header">
          <div class="div-label" style="background-color: var(--gold); color: var(--dark);">
            How We Work
          </div>
          <h2 class="div-title" style="margin-top: 1rem; color: var(--white);">
            From Conception to Reality.
          </h2>
          <p style="font-size: 1.1rem; opacity: 0.6; margin-top: 1rem; color: var(--white);">
            Our dual-focus allows us to approach every project with a blend of
            creative artistry and technical precision.
          </p>
        </div>

        <div class="process-steps">
          <div class="step-row">
            <div class="step-number">01</div>
            <div class="step-title">Discovery</div>
            <div class="step-desc">
              We listen to your needs, whether it's a software blueprint or a
              specific style of modest wear.
            </div>
          </div>
          <div class="step-row">
            <div class="step-number">02</div>
            <div class="step-title">Crafting</div>
            <div class="step-desc">
              Our experts begin the development or tailoring process, focusing
              on precision and aesthetic excellence.
            </div>
          </div>
          <div class="step-row">
            <div class="step-number">03</div>
            <div class="step-title">Quality Check</div>
            <div class="step-desc">
              Every line of code is tested, and every garment is inspected to
              meet the Al Manāb seal of approval.
            </div>
          </div>
          <div class="step-row">
            <div class="step-number">04</div>
            <div class="step-title">Delivery</div>
            <div class="step-desc">
              Based in Port Harcourt, we deliver our products and digital
              services across Nigeria with speed and care.
            </div>
          </div>
        </div>
      </div>
    </section>

  </div>
  <!-- END .horizontal-sections -->

  <!-- APPARELS─
       Lives OUTSIDE the horizontal wrapper — scrolls normally.
  -->
  <section id="apparels" class="division apparels-section">
    <div class="division-inner">
      <div class="div-image-container">
        <img
src="/src/assets/almanab-apparels.png"          alt="Premium Fabric and Apparels"
          class="div-image img-apparel"
        />
      </div>
      <div class="div-content">
        <div class="div-label">Al Manāb Apparels</div>
        <h2 class="div-title">Elegance in Modesty.</h2>
        <p class="div-text">
          Discover our exclusive collection of Islamic attire. Meticulously
          tailored for comfort and dignity, our garments celebrate cultural
          heritage without compromising on modern aesthetic and quality.
        </p>
        <ul class="features-list">
          <li><i data-lucide="shirt"></i> Premium Quality Jallabiyas/Thobes</li>
          <li><i data-lucide="circle-dashed"></i> Culturally Authentic Caps and Veils</li>
          <li><i data-lucide="check-circle-2"></i> Specialized Arabian Style Clothing</li>
        </ul>
        <div class="social-links" style="margin-top: 2rem;">
          <a href="mailto:almanabapparels@gmail.com">
            <i data-lucide="mail" style="width: 18px;"></i>
            almanabapparels@gmail.com
          </a>
          <a href="https://instagram.com/almanab.apparels" target="_blank">
            <i data-lucide="instagram" style="width: 18px;"></i>
            @almanab.apparels
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- VALUES -->
  <section id="about" class="values-section">
    <div class="div-label">Our Philosophy</div>
    <h2 class="div-title" style="margin-top: 1rem;">Values that Drive Us.</h2>
    <div class="values-grid">
      <div class="value-card">
        <i data-lucide="shield-check"></i>
        <h3>Authenticity</h3>
        <p>
          Whether it's a line of code or a stitch in a Jallabiya, we stay true
          to the highest standards of quality and cultural integrity.
        </p>
      </div>
      <div class="value-card">
        <i data-lucide="zap"></i>
        <h3>Innovation</h3>
        <p>
          We are constantly evolving, using the latest technologies to solve
          problems and modern designs to refresh tradition.
        </p>
      </div>
      <div class="value-card">
        <i data-lucide="users"></i>
        <h3>Empowerment</h3>
        <p>
          Through our tech trainings, we equip the next generation of Nigerian
          developers with world-class skills.
        </p>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer id="contact" class="footer">
    <div class="footer-grid">
      <div class="footer-col">
        <h3>AL MANĀB GROUP</h3>
        <a href="/">
          <img src={icon.src} alt="AL MANAB" width="150" />
        </a>
        <p style="font-weight: 500; opacity: 0.9; margin-top: 1rem;">
          Bridging Tradition and the Future.
        </p>
        <p style="margin-top: 1rem; opacity: 0.8;">
          Port Harcourt, Rivers State.<br />Serving clients nationwide.
        </p>
      </div>

      <div class="footer-col">
        <h3>Contact Us</h3>
        <div class="contact-item">
          <i data-lucide="phone"></i>
          <span>+234 905 790 1776</span>
        </div>
        <div class="contact-item">
          <i data-lucide="mail"></i>
          <div style="display: flex; flex-direction: column; gap: 0.2rem;">
            <a href="mailto:almanabtech@gmail.com">almanabtech@gmail.com</a>
            <a href="mailto:almanabapparels@gmail.com">almanabapparels@gmail.com</a>
          </div>
        </div>
      </div>

      <div class="footer-col">
        <h3>Connect</h3>
        <div class="social-links" style="flex-direction: column; align-items: flex-start; margin-top: 0;">
          <a href="https://instagram.com/almanab.tech" target="_blank" style="background: transparent; padding: 0;">
            <i data-lucide="instagram" style="width: 20px;"></i>
            @almanab.tech
          </a>
          <a href="https://instagram.com/almanab.apparels" target="_blank" style="background: transparent; padding: 0;">
            <i data-lucide="instagram" style="width: 20px;"></i>
            @almanab.apparels
          </a>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      &copy; 2026 Al Manāb Group. All rights reserved.
    </div>
  </footer>

</body>
</html>


<script>
  import "../scripts/animations.ts";
</script>